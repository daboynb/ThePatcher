<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape
            android:shape="ring"
            android:useLevel="false"
            android:innerRadius="14dp"
            android:thickness="1.75dp">
            <solid android:color="0x7f060093"/>
            <size
                android:height="35dp"
                android:width="35dp"/>
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <shape
            android:shape="ring"
            android:useLevel="true"
            android:innerRadius="14dp"
            android:thickness="1.75dp">
            <solid android:color="0x7f060083"/>
            <size
                android:height="35dp"
                android:width="35dp"/>
        </shape>
    </item>
</layer-list>
