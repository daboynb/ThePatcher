<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android" android:variablePadding="false">
    <item
        android:state_enabled="true"
        android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="0x7f0601d0"/>
            <stroke
                android:width="1dp"
                android:color="0x7f0601d2"/>
            <size
                android:height="0x7f070009"
                android:width="0x7f070009"/>
        </shape>
    </item>
    <item android:state_enabled="true">
        <shape android:shape="oval">
            <solid android:color="0x7f060003"/>
            <stroke
                android:width="1dp"
                android:color="0x7f0601d1"/>
            <size
                android:height="0x7f070009"
                android:width="0x7f070009"/>
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="oval">
            <solid android:color="0x7f060003"/>
            <stroke
                android:width="1dp"
                android:color="0x7f0601d1"/>
            <size
                android:height="0x7f070009"
                android:width="0x7f070009"/>
        </shape>
    </item>
</selector>
