<?xml version="1.0" encoding="utf-8"?>
<com.facebook.optic.view.AspectRatioFrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center"
    android:id="0x7f0b2f08"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.cardview.widget.CardView
        android:layout_gravity="center"
        android:id="0x7f0b2eeb"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="8dp">
        <ImageView
            android:layout_gravity="center"
            android:id="0x7f0b2018"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:adjustViewBounds="true"
            android:keepScreenOn="true"/>
        <view
            android:layout_gravity="center"
            android:id="0x7f0b4617"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:keepScreenOn="true"
            class="android.view.SurfaceView"/>
        <ImageView
            android:layout_gravity="center"
            android:id="0x7f0b21f3"
            android:visibility="gone"
            android:layout_width="0x7f070085"
            android:layout_height="0x7f070085"
            android:src="0x7f081d47"/>
        <ImageButton
            android:id="0x7f0b25dd"
            android:background="0x7f082c22"
            android:padding="6dp"
            android:visibility="gone"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="0x7f081d40"
            android:scaleType="fitCenter"/>
    </androidx.cardview.widget.CardView>
</com.facebook.optic.view.AspectRatioFrameLayout>
