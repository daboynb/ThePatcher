    </item>
    <item
        android:state_enabled="false"
        android:state_checked="false">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <size
                        android:height="0x7f070013"
                        android:width="0x7f070013"/>
                    <corners android:radius="0x7f070092"/>
                    <stroke
                        android:width="0x7f070049"
                        android:color="0x7f060126"/>
                    <solid android:color="0x7f060123"/>
                </shape>
            </item>
        </layer-list>
