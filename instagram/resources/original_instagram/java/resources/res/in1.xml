<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_enabled="true"
        android:state_checked="true"
        android:drawable="0x7f082a5a"/>
    <item
        android:state_enabled="false"
        android:state_checked="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <size
                        android:height="0x7f070013"
                        android:width="0x7f070013"/>
                    <corners android:radius="0x7f070092"/>
                    <solid android:color="0x7f060123"/>
                </shape>
            </item>
            <item
                android:gravity="center"
                android:left="0x7f070006"
                android:top="0x7f070006"
                android:right="0x7f070006"
                android:bottom="0x7f070006">
                <bitmap
                    android:src="0x7f0820c0"
                    android:tint="0x7f060126"/>
