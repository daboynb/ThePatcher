<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <corners android:radius="0x7f070022"/>
            <gradient
                android:startColor="0x7f0604e0"
                android:endColor="0x7f060113"
                android:angle="0"
                android:type="linear"/>
        </shape>
    </item>
    <item android:state_hovered="true">
        <shape>
            <corners android:radius="0x7f070022"/>
            <gradient
                android:startColor="0x7f060117"
                android:endColor="0x7f060112"
                android:angle="0"
                android:type="linear"/>
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="0x7f070022"/>
            <solid android:color="#63505050"/>
        </shape>
    </item>
</selector>
