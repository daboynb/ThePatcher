<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:gravity="center">
        <shape android:shape="rectangle">
            <corners android:radius="0x7f07015b"/>
            <size android:height="0x7f070048"/>
            <solid android:color="0x7f060121"/>
        </shape>
    </item>
    <item android:gravity="center">
        <clip>
            <scale android:scaleWidth="100%">
                <shape android:shape="rectangle">
                    <corners android:radius="0x7f07015b"/>
                    <size android:height="0x7f070048"/>
                    <gradient
                        android:startColor="0x7f06049b"
                        android:endColor="0x7f06049a"
                        android:angle="0"/>
                </shape>
            </scale>
        </clip>
    </item>
</layer-list>
