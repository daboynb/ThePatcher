<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android" android:variablePadding="false">
    <item
        android:state_enabled="true"
        android:state_pressed="true">
        <shape>
            <solid android:color="0x7f0601cd"/>
            <stroke
                android:width="1dp"
                android:color="0x7f0601cd"/>
            <corners android:radius="0x7f070006"/>
            <padding
                android:left="0x7f070013"
                android:top="0x7f070035"
                android:right="0x7f070013"
                android:bottom="0x7f070035"/>
        </shape>
    </item>
    <item android:state_enabled="true">
        <shape>
            <solid android:color="0x7f0601cb"/>
            <stroke
                android:width="1dp"
                android:color="0x7f0601cb"/>
            <corners android:radius="0x7f070006"/>
            <padding
                android:left="0x7f070013"
                android:top="0x7f070035"
                android:right="0x7f070013"
                android:bottom="0x7f070035"/>
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape>
            <solid android:color="0x7f0601a7"/>
            <corners android:radius="0x7f070006"/>
            <padding
                android:left="0x7f070013"
                android:top="0x7f070035"
                android:right="0x7f070013"
                android:bottom="0x7f070035"/>
        </shape>
    </item>
</selector>
