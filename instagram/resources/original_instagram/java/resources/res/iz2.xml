<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="0x7f06009f"/>
            <stroke
                android:width="2dp"
                android:color="0x7f0600cb"/>
        </shape>
    </item>
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">
        <bitmap
            android:gravity="center"
            android:src="0x7f082192"
            android:tint="0x7f0600cb"/>
    </item>
</layer-list>
