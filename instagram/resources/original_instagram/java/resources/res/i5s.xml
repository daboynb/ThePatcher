<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <size
                android:height="0x7f070019"
                android:width="0x7f070019"/>
            <gradient
                android:startColor="#2f3a2e"
                android:endColor="#4c584b"
                android:angle="135"
                android:type="linear"
                android:centerColor="#083f1e"/>
        </shape>
    </item>
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="oval">
            <size
                android:height="0x7f070019"
                android:width="0x7f070019"/>
            <solid android:color="#083f1e"/>
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <size
                android:height="0x7f070019"
                android:width="0x7f070019"/>
            <gradient
                android:startColor="#4d000000"
                android:endColor="#4dffffff"
                android:useLevel="false"
                android:angle="135"
                android:type="linear"/>
        </shape>
    </item>
</layer-list>
