<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android"
    android:variablePadding="false"
    android:constantSize="true">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="0x7f0601f8"/>
            <corners android:radius="0x7f070006"/>
            <padding
                android:left="12dp"
                android:top="12dp"
                android:right="12dp"
                android:bottom="12dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#00000000"/>
            <padding
                android:left="12dp"
                android:top="12dp"
                android:right="12dp"
                android:bottom="12dp"/>
        </shape>
    </item>
</selector>
