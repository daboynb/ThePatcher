<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="0x7f0600ab"/>
            <stroke
                android:width="0x7f070028"
                android:color="0x7f0600ad"/>
            <corners android:radius="0x7f070006"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="0x7f0600a7"/>
            <stroke
                android:width="0x7f070028"
                android:color="0x7f0600ad"/>
            <corners android:radius="0x7f070006"/>
        </shape>
    </item>
</selector>
