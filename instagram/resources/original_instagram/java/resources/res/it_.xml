<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <size
                android:height="24dp"
                android:width="24dp"/>
            <solid android:color="0x7f06027f"/>
        </shape>
    </item>
    <item
        android:left="4dp"
        android:top="4dp"
        android:right="4dp"
        android:bottom="4dp">
        <bitmap
            android:gravity="center"
            android:src="0x7f081f7b"
            android:tint="0x7f0600a8"/>
    </item>
</layer-list>
