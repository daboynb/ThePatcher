<?xml version="1.0" encoding="utf-8"?>
<animator xmlns:android="http://schemas.android.com/apk/res/android"
    android:duration="700"
    android:valueFrom="0"
    android:valueTo="1"
    android:valueType="floatType">
    <propertyValuesHolder>
        <keyframe
            android:value="0"
            android:fraction="0"/>
        <keyframe
            android:value="1.4"
            android:fraction="0.2"/>
        <keyframe
            android:value="0.7"
            android:fraction="0.4"/>
        <keyframe
            android:value="1.1"
            android:fraction="0.9"/>
        <keyframe
            android:value="1"
            android:fraction="1"/>
    </propertyValuesHolder>
</animator>
