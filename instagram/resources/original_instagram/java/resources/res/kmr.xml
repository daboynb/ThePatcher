<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <com.instagram.honolulu.zoom.ZoomSelectorView
        android:id="0x7f0b4806"
        android:layout_width="194dp"
        android:layout_height="194dp"
        app:pill_color="@android:color/white"
        app:pill_height="26dp"
        app:pill_text_color="@android:color/black"
        app:pill_text_size="14sp"
        app:track_background_color="0x7f060059"
        app:track_height="32dp"
        app:track_outline_color="0x7f0604e0"
        app:track_outline_width="1dp"
        app:track_sweep_angle="130"
        app:track_text_color="@android:color/white"
        app:track_text_size="14sp"/>
    <com.instagram.honolulu.capture.ShutterButtonView
        android:layout_gravity="center"
        android:id="0x7f0b3c1d"
        android:layout_width="112dp"
        android:layout_height="112dp"
        app:button_color="@android:color/white"
        app:circle_spacing="2dp"
        app:inner_circle_shrink_scale_delta="0.25"
        app:outer_circle_grow_scale_delta="0.34"
        app:outer_circle_stroke_width="4dp"
        app:outer_ring_color="@android:color/white"
        app:recording_glyph_color="0x7f0600a3"
        app:resting_scale="0.66"/>
</FrameLayout>
