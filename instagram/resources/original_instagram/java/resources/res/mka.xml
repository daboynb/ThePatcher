<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:layout_gravity="center"
        android:background="0x7f0602ee"
        android:padding="8dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="0x7f07006a"
        android:layout_height="0x7f07006a">
        <FrameLayout
            android:id="0x7f0b32e3"
            android:background="0x7f082af6"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="12dp"
            android:rotation="-6">
            <ImageView
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="0x7f08259b"
                android:tint="0x7f0602f0"/>
        </FrameLayout>
        <FrameLayout
            android:id="0x7f0b32e5"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="12dp">
            <ImageView
                android:layout_gravity="center"
                android:id="0x7f0b32ea"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:rotation="2"/>
            <ImageView
                android:layout_gravity="center"
                android:id="0x7f0b32e9"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:rotation="16"/>
            <ImageView
                android:layout_gravity="center"
                android:id="0x7f0b32e4"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:rotation="-12"/>
        </FrameLayout>
        <ImageView
            android:layout_gravity="end"
            android:id="0x7f0b1e3d"
            android:layout_width="0x7f070000"
            android:layout_height="0x7f070000"
            android:src="0x7f081f6c"
            android:layout_alignParentRight="true"/>
    </FrameLayout>
</FrameLayout>
