<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_first="true"
        android:state_last="true"
        android:state_pressed="true">
        <shape>
            <solid android:color="0x7f0601f6"/>
            <corners android:radius="0x7f070092"/>
        </shape>
    </item>
    <item
        android:state_first="true"
        android:state_pressed="true">
        <shape>
            <solid android:color="0x7f0601f6"/>
            <corners
                android:topLeftRadius="0x7f070092"
                android:topRightRadius="0x7f070092"/>
        </shape>
    </item>
    <item
        android:state_last="true"
        android:state_pressed="true">
        <shape>
            <solid android:color="0x7f0601f6"/>
            <corners
                android:bottomLeftRadius="0x7f070092"
                android:bottomRightRadius="0x7f070092"/>
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="0x7f0601f6"/>
        </shape>
    </item>
</selector>
