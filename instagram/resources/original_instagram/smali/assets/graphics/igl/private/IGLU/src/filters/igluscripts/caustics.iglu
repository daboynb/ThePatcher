[Filter CausticsFilter]

[Init]
fun init(Filter filter) {
  filter.passes = {{
      name = 'pass0, inputs = {'default},
      uniforms = {
            time = 0.0,
            speed = 1.0,
            scale = 1.0,
            aberration = 0.05,
            lower = 0.0,
            upper = 1.0,
            strength = 1.0,
            inputSize = {100.0, 100.0},
      },
      glslShader = glsl, metalShader = metal
    }};
}

[PreRender]
fun preRender(Filter filter) {
  f32 time = getParameterFloat('time_sec);
  vec2 inputSize = getTextureSize('default);
  setShaderUniform('pass0, 'inputSize, inputSize);
  setShaderUniform('pass0, 'time, time);
}

string glsl = "
  varying vec2 sourceTextureCoordinate;

  BaseUniformsOpenGL;

  uniform float time;
  uniform float speed;
  uniform float scale;
  uniform float aberration;
  uniform float lower;
  uniform float upper;
  uniform vec2 inputSize;

  float F(inout vec4 k, float v) {
    return length(.5 - fract(k.xyw *= mat3(-2, -1, 2, 3, -2, 1, 1, 2, 2) * v));
  }

  float caustics(vec2 uv, float scale, float time, float speed, float timeOffset){
    vec2 uvs = .5 + (uv - .5) * 100. * scale;
    float t = time * speed + timeOffset;
    vec4 k = vec4(0., 0., 0., t);
    k.xy = uvs * (2.) / 2e2;
    return pow(min(min(F(k, .5), F(k, .4)), F(k, .3)), 7.) * 25.;
  }

  void main() {

    vec2 uv = sourceTextureCoordinate;
    vec4 base = sampleInput(uv);

    // scale the noise to fit the clip uvs
    uv.y *= inputSize.y / inputSize.x;

    float r = caustics(uv, scale, time, speed, aberration);
    float g = caustics(uv, scale, time, speed, 0.0);
    float b = caustics(uv, scale, time, speed, -aberration);
    r = smoothstep(lower, upper, r);
    g = smoothstep(lower, upper, g);
    b = smoothstep(lower, upper, b);

    vec4 color = base + vec4(r, g, b, 0.) * strength;
    gl_FragColor = toOutputFormat(color);
  }
";

string metal = "
  typedef struct { float2 sourceTextureCoordinate [[user(locn1)]]; } RasterizerData;

  typedef struct {
    BaseUniformsMetal;
    float time;
    float speed;
    float scale;
    float aberration;
    float lower;
    float upper;
    float2 inputSize;
  } Uniforms;

  float F(thread float4& k, float v) {
    k.xyw = k.xyw * (float3x3(float3(-2, -1, 2), float3(3, -2, 1), float3(1, 2, 2)) * v);
    return length(.5 - fract(k.xyw));
  }

  float caustics(float2 uv, float scale, float time, float speed, float timeOffset){
    float2 uvs = .5 + (uv - .5) * 100. * scale;
    float t = time * speed + timeOffset;
    float4 k = float4(0., 0., 0., t);
    k.xy = uvs * (2.) / 2e2;
    return pow(min(min(F(k, .5), F(k, .4)), F(k, .3)), 7.) * 25.;
  }

  fragment float4 fragmentShader(RasterizerData fragmentIn [[stage_in]],
                                  constant Uniforms & uniforms [[buffer(1)]],
                                  DefaultInputs defaultInputs) {

    float2 uv = fragmentIn.sourceTextureCoordinate;
    float4 base = sampleInput(defaultInputs, uv);

    // scale the noise to fit the clip uvs
    uv.y *= uniforms.inputSize.y / uniforms.inputSize.x;

    float r = caustics(uv, uniforms.scale, uniforms.time, uniforms.speed, uniforms.aberration);
    float g = caustics(uv, uniforms.scale, uniforms.time, uniforms.speed, 0.0);
    float b = caustics(uv, uniforms.scale, uniforms.time, uniforms.speed, -uniforms.aberration);
    r = smoothstep(uniforms.lower, uniforms.upper, r);
    g = smoothstep(uniforms.lower, uniforms.upper, g);
    b = smoothstep(uniforms.lower, uniforms.upper, b);

    //float4 color = float4(r, g, b, 0.) * uniforms.strength;
    float4 color = base + float4(r, g, b, 0.) * uniforms.strength;
    return toOutputFormat(color);
  }
";
