[Filter IgluscriptWideAngleFilter]

[Init]
fun init(Filter filter) {
  filter.passes = {
    {
      name = 'pass0,
      inputs = {'default},
      uniforms = { strength = 1.0,  uInputImageSize = {100.0, 100.0}},
      glslShader  = glslShader,
      metalShader = metalShader
    }
    };
}


[PreRender]
fun preRender(Filter filter){
    vec2 textureSize = getTextureSize('default);

    setShaderUniform('pass0,'uInputImageSize, textureSize);
}

string glslShader = "
        varying vec2 sourceTextureCoordinate;

                      BaseUniformsOpenGL;
                      uniform vec2 uInputImageSize;

                      void main() {
                        // constants (can be moved to uniforms in the future)
                        const float fishEyeSize = 0.697;
                        const float falloff = 2.0;
                        float amount = 0.31 * strength;


                        // aspect ratio correction
                        vec2 res = uInputImageSize;
                        float longestSide = step(res.y, res.x);
                        float aspect = res.x / res.y;
                        vec2 correction = vec2(mix(aspect, 1.0, longestSide),
                                               mix(1.0, 1.0 / aspect, longestSide));

                        // distort uvs
                        vec2 uv = sourceTextureCoordinate * 2.0 - 1.0;
                        vec2 duv = uv * correction * fishEyeSize;
                        float l = 1.0 - pow(length(duv), falloff);
                        uv *= clamp(1.0 - l * amount, 0.0, 1.0);
                        uv = uv * 0.5 + 0.5;

                        // sample color
                        vec4 color = sampleInput(uv);
                        gl_FragColor = toOutputFormat(color);
                      }
                      ";

string metalShader = "

      typedef struct { float2 sourceTextureCoordinate [[user(locn1)]]; } RasterizerData;

      typedef struct {
        BaseUniformsMetal;
        float2 uInputImageSize;
      } Uniforms;

      fragment float4 fragmentShader(RasterizerData fragmentIn [[stage_in]],
                                     constant Uniforms & uniforms [[buffer(1)]],
                                     DefaultInputs defaultInputs) {
        const float fishEyeSize = 0.697;
        const float falloff = 2.0;
        float amount = 0.31 * uniforms.strength;

        float2 res = uniforms.uInputImageSize;
        float longestSide = step(res.y, res.x);
        float aspect = res.x / res.y;
        float2 correction =
            float2(mix(aspect, 1.0, longestSide), mix(1.0, 1.0 / aspect, longestSide));

        float2 uv = fragmentIn.sourceTextureCoordinate * 2.0 - 1.0;
        float2 duv = uv * correction * fishEyeSize;
        float l = 1.0 - pow(length(duv), falloff);
        uv *= clamp(1.0 - l * amount, 0.0, 1.0);
        uv = uv * 0.5 + 0.5;

        float4 color = sampleInput(defaultInputs, uv);
        return toOutputFormat(color);
      }
      ";
