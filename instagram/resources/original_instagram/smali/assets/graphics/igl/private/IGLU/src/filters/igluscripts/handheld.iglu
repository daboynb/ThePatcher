[Filter Handheld]
# replicate the Handheld filter in IGLUScript

[Init]
fun init(Filter filter)
{
    # list the passes in order you want them evaluated
    filter.passes = {{
      name = 'radialBlur0,
      inputs = {'default},
      uniforms = {
        strength = 1.0,
        blurAmt = 3.0,
        samples = 16.0,
        contrast = 0.0,
        brightness = 0.0,
        saturation = 0.0,
        colorCorrect = 0.0,
        position = {0.3,0.3},
        uInputImageSize = {1.0,1.0}
      },
      glslShader  = glslRadialBlur,
      metalShader = metalRadialBlur
    },{
      name = 'radialBlur1,
      inputs = {'radialBlur0},
      uniforms = {
        strength = 1.0,
        blurAmt = 1.5,
        samples = 8.0,
        contrast = 0.252,
        brightness = 0.1,
        saturation = -0.02,
        colorCorrect = 0.0,
        position = {-0.25,0.48},
        uInputImageSize = {1.0,1.0}
      },
      glslShader  = glslRadialBlur,
      metalShader = metalRadialBlur,
    }};

}

[PreRender]
fun preRender(Filter filter){
    f32 strength = getParameterFloat('strength);

    vec2 size = getTextureSize('default);
    setShaderUniform('radialBlur0,'uInputImageSize, size);
    setShaderUniform('radialBlur1,'uInputImageSize, size);

    setShaderUniform('radialBlur0,'blurAmt, strength * 3.0);
    setShaderUniform('radialBlur0,'contrast, strength * 0.0);
    setShaderUniform('radialBlur0,'brightness, strength * 0.0);
    setShaderUniform('radialBlur0,'saturation, strength * 0.0);
    setShaderUniform('radialBlur0,'colorCorrect, strength * 0.0);

    setShaderUniform('radialBlur1, 'blurAmt, strength * 1.5);
    setShaderUniform('radialBlur1, 'contrast, strength * 0.252);
    setShaderUniform('radialBlur1, 'brightness, strength * 0.1);
    setShaderUniform('radialBlur1, 'saturation, strength * -0.02);
    setShaderUniform('radialBlur1, 'colorCorrect, strength * 0.0);
}



#### GLSL shaders ####

# single pass shader that copies source to dest
string glslRadialBlur = "
#define PI 3.1415926535897932384626433832795
      precision highp float;

      varying vec2 sourceTextureCoordinate;

      BaseUniformsOpenGL; // overall filter strength
      uniform float blurAmt;
      uniform float samples;
      uniform float colorCorrect;
      uniform float contrast;
      uniform float brightness;
      uniform float saturation;
      uniform vec2 position;
      uniform vec2 uInputImageSize;

      mat2 rotate2d(float rads) {
        float c = cos(rads);
        float s = sin(rads);
        return mat2(c, s, -s, c);
      }

      vec4 radialBlur(vec2 uv, vec2 position, float samples, float spin) {
        vec4 color = vec4(0.0);
        float angle = (PI / 180.0) * spin / samples;

        // starting rotated uv
        vec2 rotUv = (uv - position) * uInputImageSize * rotate2d(-angle * samples / 2.0);

        // rotation matrix to reuse in the sampling loop
        mat2 rot = rotate2d(angle);

        const float maxSamples = 30.0;

        for (float i = 0.0; i < maxSamples; i++) {
          if (i >= samples)
            break;

          rotUv = rotUv * rot; // rotate uv by small increments
          vec2 st = rotUv / uInputImageSize + position; // undo aspect ratio correction
          color += sampleInput(st);
        }
        return color / samples;
      }

      vec3 colorSaturation(vec3 color, float amount) {
        return mix(vec3(dot(vec3(0.3086, 0.6094, 0.0820), color)), color, amount);
      }

      float luma(vec3 color) { return dot(color, vec3(0.299, 0.587, 0.114)); }

      vec3 brightnessContrast(vec3 value, float brightness, float contrast) {
        return (value - 0.5 + brightness) * (1.0 + contrast) + 0.5;
      }

      void main() {
        vec2 uv = sourceTextureCoordinate;
        vec4 color = radialBlur(uv, position, floor(samples), blurAmt);
        float alpha = color.a;
        float l = luma(color.rgb);
        color += colorCorrect * smoothstep(0.0, 0.5, l) * smoothstep(1.0, 0.5, l);
        color.rgb = colorSaturation(color.rgb, 1.0 + saturation);
        color.rgb = brightnessContrast(color.rgb, brightness, contrast);
        color.a = alpha;
        gl_FragColor = toOutputFormat(color);
      }
";


#### Metal shaders ####

string metalRadialBlur = "
typedef struct { float2 sourceTextureCoordinate [[user(locn1)]]; } RasterizerData;

      typedef struct {
        BaseUniformsMetal;
        float blurAmt;
        float samples;
        float contrast;
        float brightness;
        float saturation;
        float colorCorrect;
        float2 position;
        float2 uInputImageSize;
      } Uniforms;

#define PI 3.1415926535897932384626433832795

      float2x2 rotate2d(float rads) {
        float c = cos(rads);
        float s = sin(rads);
        return float2x2(c, s, -s, c);
      }

      float4 radialBlur(DefaultInputs defaultInputs,
                        float2 uv,
                        float2 size,
                        float2 position,
                        float samples,
                        float spin) {
        float4 color = float4(0.0);
        float angle = (PI / 180.0) * spin / samples;

        // starting rotated uv
        float2 rotUv = (uv - position) * size * rotate2d(-angle * samples / 2.0);

        // rotation matrix to reuse in the sampling loop
        float2x2 rot = rotate2d(angle);

        const float maxSamples = 30.0;

        for (float i = 0.0; i < maxSamples; i++) {
          if (i >= samples)
            break;

          rotUv = rotUv * rot; // rotate uv by small increments
          float2 st = rotUv / size + position; // undo aspect ratio correction
          color += sampleInput(defaultInputs, st);
        }
        return color / samples;
      }

      float3 colorSaturation(float3 color, float amount) {
        return mix(float3(dot(float3(0.3086, 0.6094, 0.0820), color)), color, amount);
      }

      float luma(float3 color) { return dot(color, float3(0.299, 0.587, 0.114)); }

      float3 brightnessContrast(float3 value, float brightness, float contrast) {
        return (value - 0.5 + brightness) * (1.0 + contrast) + 0.5;
      }

      fragment float4 fragmentShader(RasterizerData fragmentIn [[stage_in]],
                                     constant Uniforms & uniforms [[buffer(1)]],
                                     DefaultInputs defaultInputs) {
        float2 uv = fragmentIn.sourceTextureCoordinate;
        float4 color = radialBlur(defaultInputs,
                                  uv,
                                  uniforms.uInputImageSize,
                                  uniforms.position,
                                  floor(uniforms.samples),
                                  uniforms.blurAmt);
        float alpha = color.a;
        float l = luma(color.rgb);
        color += uniforms.colorCorrect * smoothstep(0.0, 0.5, l) * smoothstep(1.0, 0.5, l);
        color.rgb = colorSaturation(color.rgb, 1.0 + uniforms.saturation);
        color.rgb = brightnessContrast(color.rgb, uniforms.brightness, uniforms.contrast);
        color.a = alpha;
        return toOutputFormat(color);
      }
";
