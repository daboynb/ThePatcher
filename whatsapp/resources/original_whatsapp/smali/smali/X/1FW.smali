 0\n                AND\n                message.sort_id > ?\n                AND\n                message_media.transferred = 0\n                AND\n                message_media.autotransfer_retry_enabled = 1\n                AND\n                ((? = 1 AND jid.type = 5) OR\n                 (? = 0 AND jid.type != 5))\n            ORDER BY message.sort_id ASC\n            LIMIT ?\n        "

