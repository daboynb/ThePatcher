<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape>
                    <solid android:color="0x7f06011f"/>
                    <corners
                        android:topLeftRadius="4dp"
                        android:topRightRadius="4dp"/>
                </shape>
            </item>
            <item
                android:left="-3dp"
                android:top="-3dp"
                android:right="-3dp">
                <shape>
                    <stroke
                        android:width="2dp"
                        android:color="0x7f0605ee"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <shape>
            <solid android:color="0x7f06026f"/>
            <corners android:radius="4dp"/>
        </shape>
    </item>
</selector>
