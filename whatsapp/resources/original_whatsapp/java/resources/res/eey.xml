<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <corners android:radius="0x7f0700a5"/>
            <size android:height="0x7f0700a8"/>
            <stroke
                android:width="0x7f0700a2"
                android:color="0x7f060068"/>
            <solid android:color="0x7f060067"/>
        </shape>
    </item>
    <item android:id="@android:id/progress">
        <clip>
            <shape>
                <corners android:radius="0x7f0700a5"/>
                <size android:height="0x7f0700a8"/>
                <solid android:color="0x7f060069"/>
            </shape>
        </clip>
    </item>
</layer-list>
