<?xml version="1.0" encoding="utf-8"?>
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:insetLeft="0x7f07000b"
    android:insetRight="0x7f07000b"
    android:insetTop="0x7f07000c"
    android:insetBottom="0x7f07000c">
    <ripple android:color="?android:attr/colorControlHighlight">
        <item>
            <selector>
                <item android:state_enabled="false">
                    <shape android:shape="rectangle">
                        <corners android:radius="0x7f070011"/>
                        <solid android:color="?android:attr/colorButtonNormal"/>
                        <padding
                            android:left="0x7f07000d"
                            android:top="0x7f07000e"
                            android:right="0x7f07000d"
                            android:bottom="0x7f07000e"/>
                    </shape>
                </item>
                <item>
                    <shape android:shape="rectangle">
                        <corners android:radius="0x7f070011"/>
                        <solid android:color="?android:attr/colorAccent"/>
                        <padding
                            android:left="0x7f07000d"
                            android:top="0x7f07000e"
                            android:right="0x7f07000d"
                            android:bottom="0x7f07000e"/>
                    </shape>
                </item>
            </selector>
        </item>
    </ripple>
</inset>
