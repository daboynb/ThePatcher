<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:padding="0x7f070564"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:background="0x7f0602b5"
        android:padding="0x7f070564"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="14sp"
            android:textColor="0x7f0602b7"
            android:ellipsize="end"
            android:id="0x7f0b04ae"
            android:padding="0x7f070564"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="2"/>
        <LinearLayout
            android:gravity="end"
            android:paddingTop="0x7f070563"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="0x7f070566"
                android:textStyle="bold"
                android:textColor="0x7f0602b6"
                android:id="0x7f0b04ad"
                android:padding="0x7f070564"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MUTE"/>
            <TextView
                android:textSize="0x7f070566"
                android:textStyle="bold"
                android:textColor="0x7f0602b6"
                android:id="0x7f0b04af"
                android:padding="0x7f070564"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="0x7f070565"
                android:layout_marginRight="0x7f070565"
                android:text="VIEW"
                android:layout_marginHorizontal="0x7f070565"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
