<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="0x7f0809aa"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.whatsapp.payments.common.ui.widget.PayToolbar
        android:id="0x7f0b1e7e"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        app:NOT_FOUND_0x8="0dp"
        app:NOT_FOUND_0x9="0dp"/>
    <View
        android:id="0x7f0b2c22"
        android:background="0x7f0605a4"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="0x7f0b1ea0"
        android:scrollbars="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</LinearLayout>
