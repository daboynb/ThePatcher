                android:textAppearance="0x7f1503eb"
                android:ellipsize="end"
                android:id="0x7f0b2a70"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"/>
        </LinearLayout>
        <com.whatsapp.ui.wds.components.button.WDSButton
            android:id="0x7f0b00bc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0x7f120199"
            android:layout_marginEnd="0x7f07075d"
            app:NOT_FOUND_0xf="2"
            app:NOT_FOUND_0x10="small"/>
    </LinearLayout>
    <ViewStub
        android:layout_gravity="bottom"
        android:id="0x7f0b26e0"
        android:layout="0x7f0e0a9f"
        android:layout_width="match_parent"
        android:layout_height="1dp"/>
</FrameLayout>
