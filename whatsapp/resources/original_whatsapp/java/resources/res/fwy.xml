<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="0x7f0b1829"
    android:background="#fff"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="horizontal"
        android:id="0x7f0b2c1e"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp">
        <ImageView
            android:id="0x7f0b03cd"
            android:visibility="gone"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginRight="5dp"/>
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="50dp">
            <TextView
                android:textSize="14sp"
                android:textColor="0x7f060553"
                android:ellipsize="end"
                android:gravity="top"
                android:id="0x7f0b2cff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="182dp"
                android:maxLines="1"
                android:fontFamily="sans-serif-medium"/>
            <TextView
                android:textSize="18sp"
                android:textColor="0x7f060553"
                android:gravity="bottom"
                android:id="0x7f0b2d00"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="xxxx3456"
                android:maxLines="1"
                android:layout_below="0x7f0b2cff"
                android:fontFamily="sans-serif-medium"/>
        </RelativeLayout>
        <android.widget.Space
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <ImageView
            android:layout_gravity="center_vertical"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:src="0x7f0806c5"/>
    </LinearLayout>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">
                <FrameLayout
                    android:orientation="vertical"
                    android:id="0x7f0b1828"
                    android:background="#fff"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </ScrollView>
            <LinearLayout
                android:layout_gravity="bottom"
                android:orientation="vertical"
                android:id="0x7f0b169b"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true">
                <include
                    android:id="0x7f0b20b6"
                    android:visibility="gone"
                    layout="0x7f0e0993"/>
                <org.npci.upi.security.pinactivitycomponent.Keypad
                    android:layout_gravity="bottom"
                    android:id="0x7f0b1214"
                    android:paddingBottom="10dp"
                    android:visibility="visible"
                    android:layout_width="match_parent"
                    android:layout_height="0x7f07071b"
                    android:layoutDirection="ltr"/>
            </LinearLayout>
        </RelativeLayout>
        <include layout="0x7f0e09a1"/>
        <RelativeLayout
            android:orientation="vertical"
            android:id="0x7f0b0feb"
            android:background="#f4f4f4"
            android:visibility="gone"
            android:clickable="true"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:clickable="true"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="0x7f0804c7"
                android:layout_above="0x7f0b1cd2"
                android:layout_centerInParent="true"/>
            <TextView
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:gravity="center"
                android:id="0x7f0b1cd2"
                android:paddingLeft="32dp"
                android:paddingRight="32dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="30dp"
                android:text="0x7f124088"
                android:layout_above="0x7f0b0fec"/>
            <TextView
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="0x7f06054a"
                android:gravity="center"
                android:id="0x7f0b12b5"
                android:background="0x7f080a72"
                android:clickable="true"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_margin="20dp"
                android:text="0x7f123e93"
                android:layout_alignParentBottom="true"/>
            <TextView
                android:textSize="20sp"
                android:gravity="center"
                android:id="0x7f0b0fec"
                android:paddingLeft="32dp"
                android:paddingRight="32dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:text="0x7f123e4e"
                android:layout_above="0x7f0b12b5"/>
        </RelativeLayout>
    </FrameLayout>
</LinearLayout>
