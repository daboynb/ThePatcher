<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:background="0x7f080302"
    android:padding="0x7f0703e4"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <com.whatsapp.ui.coreui.base.WaImageView
        android:id="0x7f0b1461"
        android:paddingRight="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="fitCenter"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <com.whatsapp.ui.coreui.base.TextEmojiLabel
            android:textSize="15sp"
            android:textColor="?android:attr/textColorPrimary"
            android:ellipsize="end"
            android:id="0x7f0b2be5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:singleLine="true"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="0x7f0b1532"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="0x7f1501ad"/>
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="0x7f0b0600"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="0x7f1501ae"/>
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="0x7f0b114f"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="0x7f1501ad"/>
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="0x7f0b05fe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="0x7f1501ae"/>
            <com.whatsapp.ui.coreui.base.WaTextView
                android:id="0x7f0b1151"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="0x7f1501ad"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
