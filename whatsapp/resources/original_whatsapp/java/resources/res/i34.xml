<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="0x7f0605f3"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:id="0x7f0b13b3"
        android:background="0x7f0605e5"
        android:paddingLeft="4dp"
        android:paddingRight="4dp"
        android:layout_width="match_parent"
        android:layout_height="48dp">
        <ImageView
            android:id="0x7f0b1802"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="2dp"
            android:src="0x7f080160"
            android:contentDescription="0x7f123ed3"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="2dp"/>
        <LinearLayout
            android:gravity="start"
            android:orientation="vertical"
            android:paddingBottom="3dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:ellipsize="end"
                android:id="0x7f0b2be5"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0x7f123ed3"
                android:singleLine="true"
                style="0x7f150454"/>
            <TextView
                android:ellipsize="end"
                android:id="0x7f0b2a70"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-3dp"
                android:singleLine="true"
                style="0x7f150451"/>
        </LinearLayout>
    </LinearLayout>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ListView
            android:id="0x7f0b1783"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="0x7f0802ff"
            android:dividerHeight="0.5dp"/>
        <TextView
            android:textSize="20sp"
            android:textColor="?android:attr/textColorSecondaryNoDisable"
            android:gravity="center"
            android:id="0x7f0b0f5f"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginLeft="8dp"
            android:layout_marginRight="8dp"
            android:text="0x7f124084"/>
        <TextView
            android:textSize="18sp"
            android:textColor="?android:attr/textColorSecondaryNoDisable"
            android:gravity="center"
            android:id="0x7f0b2907"
            android:paddingTop="8dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="0x7f07105a"
            android:layout_marginRight="8dp"
            android:text="0x7f124084"/>
    </FrameLayout>
</LinearLayout>
