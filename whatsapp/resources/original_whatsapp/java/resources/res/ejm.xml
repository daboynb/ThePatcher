<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <stroke
                        android:width="2dp"
                        android:color="0x7f0609a6"/>
                </shape>
            </item>
            <item
                android:left="12dp"
                android:top="12dp"
                android:right="12dp"
                android:bottom="12dp">
                <bitmap
                    android:src="0x7f080467"
                    android:tint="0x7f0609a6"/>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <stroke
                android:width="2dp"
                android:color="0x7f0609a6"/>
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <stroke
                android:width="0.5dp"
                android:color="0x7f0609ac"/>
        </shape>
    </item>
</selector>
